# Supabase (EU West / London region)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OpenAI (Whisper transcription)
OPENAI_API_KEY=sk-your-openai-key

# Anthropic (extraction pipeline, chat, agents)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# Public base URL of the deployment (used for OAuth redirects and cron self-calls)
NEXT_PUBLIC_APP_URL=https://cortex.ictusflow.com

# Google OAuth (Calendar read + Cortex-Ops enrichment)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Email intake webhook — shared secret sent by the inbound-parse provider
# (SendGrid Inbound Parse / Mailgun route / Postmark) as x-cortex-ingest-secret.
EMAIL_INGEST_SECRET=generate-a-long-random-string

# Protects the scheduled agent endpoints (Vercel Cron sends this as a
# Bearer token / x-cron-secret header).
CRON_SECRET=generate-a-long-random-string

# Web Push (VAPID) for meeting-prep and overdue-action alerts.
# Generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:gareth@ictusflow.com
